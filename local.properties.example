# Copy this file to local.properties and fill in the paths for your machine.
# local.properties is gitignored — never commit it.

# ── Android SDK ──────────────────────────────────────────────────────────────
# Windows default: C:\Users\<you>\AppData\Local\Android\Sdk
# macOS default:   /Users/<you>/Library/Android/sdk
sdk.dir=C\:\\Users\\YOUR_USERNAME\\AppData\\Local\\Android\\Sdk

# ── JDK ──────────────────────────────────────────────────────────────────────
# Set this only if Gradle does not pick up the right JDK automatically.
# Android Studio's bundled JDK is usually at:
#   Windows: C:\Program Files\Android\Android Studio\jbr
#   macOS:   /Applications/Android Studio.app/Contents/jbr/Contents/Home
# Uncomment and set the path below if needed:
# org.gradle.java.home=C\:\\Program Files\\Android\\openjdk\\jdk-21.0.8

# ── ATAK CIV SDK ─────────────────────────────────────────────────────────────
# Point to the root of the extracted ATAK-CIV-SDK folder.
sdk.path=C\:\\path\\to\\ATAK-CIV-5.6.0-SDK

# TAK Gradle plugin — lives inside the SDK folder.
takdev.plugin=C\:\\path\\to\\ATAK-CIV-5.6.0-SDK\\atak-gradle-takdev.jar

# ── Signing keys ─────────────────────────────────────────────────────────────
# The debug keystore is auto-generated by the takdev plugin at build time;
# these values match the takdev defaults and normally do not need to change.
takDebugKeyAlias=wintec_mapping
takDebugKeyFile=C\:\\path\\to\\your\\android_keystore
takDebugKeyFilePassword=tnttnt
takDebugKeyPassword=tnttnt

takReleaseKeyAlias=wintec_mapping
takReleaseKeyFile=C\:\\path\\to\\your\\android_keystore
takReleaseKeyFilePassword=tnttnt
takReleaseKeyPassword=tnttnt
