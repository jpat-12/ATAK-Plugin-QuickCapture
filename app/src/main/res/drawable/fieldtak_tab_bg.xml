<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item android:bottom="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#24272A" />
                </shape>
            </item>
            <item android:gravity="bottom" android:height="3dp">
                <shape android:shape="rectangle">
                    <solid android:color="#DFB228" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#151719" />
        </shape>
    </item>
</selector>
