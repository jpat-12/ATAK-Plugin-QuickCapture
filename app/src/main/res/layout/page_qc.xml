<?xml version="1.0" encoding="utf-8"?>
<!-- FieldTAK — ArcGIS Quick Capture submission page -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <!-- ── URL entry + connect (always visible, doesn't scroll away) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#111111">

        <!-- Status row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/qc_project_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No project"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/qc_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not connected"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- URL field -->
        <EditText
            android:id="@+id/qc_url_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:maxLines="3"
            android:hint="https://services.arcgis.com/…/FeatureServer/0"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:textSize="10sp"
            android:background="@drawable/new_dark_button_bg"
            android:padding="8dp"
            android:inputType="textUri|textMultiLine"
            android:layout_marginBottom="8dp"/>

        <!-- Connect + Scan QR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/qc_connect_btn"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="2"
                android:text="Connect"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/new_dark_button_bg"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/qc_scan_btn"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:text="Scan QR"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:background="@drawable/new_dark_button_bg"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Scrollable form (appears after connecting) ────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Form section — shown only when connected (GONE by default) -->
            <LinearLayout
                android:id="@+id/qc_form_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Section header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SURVEY FIELDS"
                    android:textColor="#DFB228"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <!-- GPS info row (read-only, updated before submit) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#0D0D0D"
                    android:padding="10dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS  "
                        android:textColor="#888888"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/qc_gps_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Captured at submit time"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Dynamic field rows injected here -->
                <LinearLayout
                    android:id="@+id/qc_fields_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- Submit button (inside the scrollable form section) -->
                <Button
                    android:id="@+id/qc_submit_btn"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Submit Location"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/new_dark_button_bg"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>

            <!-- Clear -->
            <Button
                android:id="@+id/qc_disconnect_btn"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Clear Project"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:background="@drawable/new_dark_button_bg"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
