<?xml version="1.0" encoding="utf-8"?>
<!-- FieldTAK — GeoChat message templates page (all inside one ScrollView) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Everything scrolls together -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Send To section (now scrolls with templates) ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0D0D0D"
                android:padding="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send To"
                    android:textColor="#DFB228"
                    android:textSize="11sp"
                    android:layout_marginBottom="5dp"/>

                <!-- Target row: edit text + All Chat + Browse Contacts -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/msg_target_edit"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:hint="Callsign or UID"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:textSize="12sp"
                        android:background="@drawable/new_dark_button_bg"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:inputType="textNoSuggestions"
                        android:imeOptions="actionDone"/>

                    <Button
                        android:id="@+id/msg_all_chat_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="All Chat"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:background="@drawable/new_dark_button_bg"
                        android:layout_marginStart="4dp"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"/>

                    <Button
                        android:id="@+id/msg_contacts_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="Contacts"
                        android:textColor="#DFB228"
                        android:textSize="10sp"
                        android:background="@drawable/new_dark_button_bg"
                        android:layout_marginStart="4dp"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Template list ─────────────────────────────── -->
            <LinearLayout
                android:id="@+id/msg_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
