<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:text="FieldTAK Home"
            android:textColor="#DFB228"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/home_photo_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/new_dark_button_bg"
            android:text="TAKE PHOTO"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:text="STATUS"
            android:textColor="#DFB228"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fieldtak_panel_bg"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Connected to TAK Server"
                    android:textColor="#D5D8DA"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/home_tak_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking"
                    android:textColor="#E0C84E"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Connected to WMIRS"
                    android:textColor="#D5D8DA"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/home_wmirs_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No"
                    android:textColor="#F44336"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Connected to QuickCapture"
                    android:textColor="#D5D8DA"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/home_qc_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No"
                    android:textColor="#F44336"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/home_profile_toggle"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/new_dark_button_bg"
            android:gravity="start|center_vertical"
            android:paddingLeft="12dp"
            android:text="PROFILE  +"
            android:textColor="#DFB228"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/home_profile_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/home_callsign_edit"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1.1"
                android:background="@drawable/new_dark_button_bg"
                android:hint="Callsign"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#747A80"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/home_capid_edit"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="0.8"
                android:layout_marginStart="5dp"
                android:background="@drawable/new_dark_button_bg"
                android:hint="CAP ID"
                android:inputType="number"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#747A80"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/home_name_edit"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1.4"
                android:layout_marginStart="5dp"
                android:background="@drawable/new_dark_button_bg"
                android:hint="Name"
                android:inputType="textPersonName|textCapWords"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:singleLine="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#747A80"
                android:textSize="12sp" />

            <Button
                android:id="@+id/home_save_btn"
                android:layout_width="72dp"
                android:layout_height="42dp"
                android:layout_marginStart="5dp"
                android:background="@drawable/new_dark_button_bg"
                android:minWidth="0dp"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:text="SAVE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
